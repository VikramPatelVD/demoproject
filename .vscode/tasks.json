{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Full Build + Deploy",
      "dependsOrder": "sequence",
      "dependsOn": ["build-frontend", "copy-to-wwwroot", "publish-backend"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build-frontend",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "set REACT_APP_API_URL=/api/users",
      "command": "npm run build",
      "problemMatcher": []
    },
    {
      "label": "copy-to-wwwroot",
      "type": "shell",
      "command": "xcopy",
      "args": [
        "/E",
        "/I",
        "/Y",
        "${workspaceFolder}/frontend/build",
        "${workspaceFolder}/Backend/wwwroot"
      ],
      "problemMatcher": []
    },
    {
      "label": "publish-backend",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/Backend"
      },
      "command": "dotnet publish -c Release -o publish",
      "problemMatcher": []
    }
  ]
}
